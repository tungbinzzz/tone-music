{
  "name": "tc-studio",
  "version": "0.1.0",
  "description": "TC Studio — Realtime YouTube tone detection and Cubase control.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "node scripts/dev.js",
    "dev": "node scripts/dev.js",
    "build": "vite build",
    "build:engine": "node scripts/build-engine.js",
    "clean:release": "node scripts/clean-release.js",
    "dist:win": "npm run clean:release && npm run build && npm run build:engine && electron-builder --win",
    "pack:win": "npm run clean:release && npm run build && npm run build:engine && electron-builder --win --dir",
    "electron": "electron .",
    "install:cubase-remote": "powershell -ExecutionPolicy Bypass -File scripts/install-cubase-midi-remote.ps1"
  },
  "build": {
    "appId": "com.tcstudio.app",
    "productName": "TC Studio",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release-fixed"
    },
    "files": [
      "package.json",
      "src/main/**/*",
      "src/assets/**/*",
      "dist/renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/engine/tonelink-engine.exe",
        "to": "engine/tonelink-engine.exe"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "generic_remote",
        "to": "generic_remote"
      },
      {
        "from": "cubase_remote",
        "to": "cubase_remote"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    }
  },
  "keywords": [
    "electron",
    "cubase",
    "youtube",
    "librosa",
    "audio"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.8.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^31.7.7",
    "electron-builder": "^26.15.0",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3",
    "vite": "^7.2.7"
  }
}
