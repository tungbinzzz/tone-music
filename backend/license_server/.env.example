# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# JWT secret for offline tokens (generate with: openssl rand -hex 32)
LICENSE_JWT_SECRET=your-super-secret-key-min-32-chars

# Admin secret to protect /admin/* endpoints (generate with: openssl rand -hex 16)
ADMIN_SECRET=your-admin-secret-here

# Offline token validity in days
TOKEN_EXPIRE_DAYS=7

# App version info
APP_LATEST_VERSION=0.1.0
APP_UPDATE_URL=https://github.com/your-repo/releases/latest
